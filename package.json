{
  "name": "kavoru",
  "version": "1.0.0",
  "scripts": {
    "test": "bun test",
    "build": "bun build --compile --env=disable --minify-whitespace --minify-syntax --target bun --outfile server ./src/index.ts",
    "start": "bunx prisma generate && bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "routes:registry": "bun run scripts/generate-route-registry.ts",
    "build:docker": "bun run routes:registry && bun build --compile --env=disable --minify-whitespace --minify-syntax --target=bun-linux-x64 --outfile server ./src/index.ts",
    "start:prod": "./server",
    "seed": "bun run src/infra/prisma/seed/index.ts",
    "otel:view": "bunx otel-dev --web",
    "otel:tui": "bunx otel-dev",
    "sentry:spotlight": "bunx @spotlightjs/spotlight server -o"
  },
  "dependencies": {
    "@elysia/cron": "^1.4.2",
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/opentelemetry": "^1.4.11",
    "@elysiajs/swagger": "^1.3.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.200.0",
    "@opentelemetry/otlp-transformer": "^0.200.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/elysia": "^10.55.0",
    "elysia": "latest",
    "kafkajs": "^2.2.4",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "bun-types": "latest",
    "prisma": "^7.8.0"
  },
  "author": "https://github.com/mertthesamael",
  "license": "MIT",
  "module": "src/index.js"
}
